# Application Settings
APP_NAME=CarbonSense AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://carbonsense:password@localhost:5432/carbonsense_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_TTL=3600

# AI Model API Keys
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Model Endpoints
# Groq: llama-3.1-8b-instant
# Hugging Face: meta-llama/Meta-Llama-3-70B-Instruct
EMBEDDING_MODEL=text-embedding-3-small

# Adaptive Model Selector Settings
CARBON_BUDGET_DAILY_GRAMS=1000.0
MODEL_IDLE_TIMEOUT_SECONDS=300
QUALITY_THRESHOLD=0.7
ENABLE_MODEL_WARMUP=True
TINY_MODEL_ALWAYS_LOADED=True

# Local Model Configuration
LOCAL_MODEL_CACHE_DIR=./models
USE_GPU_IF_AVAILABLE=True

# RAG Configuration
VECTOR_DIMENSION=1536
MAX_CONTEXT_LENGTH=4096
TOP_K_RESULTS=5

# RL Optimizer Settings
RL_LEARNING_RATE=0.001
RL_DISCOUNT_FACTOR=0.95
RL_EXPLORATION_RATE=0.1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS Settings
CORS_ORIGINS='["http://localhost:3000","http://localhost:8000"]'
CORS_ALLOW_CREDENTIALS=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090
